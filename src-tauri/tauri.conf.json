{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnowPaw",
  "version": "0.1.0",
  "identifier": "dev.snowpaw.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SnowPaw",
        "width": 1100,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/snowpaw-agent"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
